# ============================================================
#  SilicaChain Platform — PHP API Environment Variables
#  Copy this file to .env and fill in your values
# ============================================================

# --- Server ---
NODE_ENV=production
APP_DEBUG=0

# --- MySQL Database ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=silica_user
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
DB_NAME=silica_db

# --- File Paths ---
PUBLIC_DIR=/home/user/domains/silicachain.io/public_html
UPLOAD_DIR=/home/user/domains/silicachain.io/public_html/uploads

# --- JWT Secrets (generate random 32+ char strings) ---
# Use: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_RANDOM_SECRET_AT_LEAST_32_CHARS
ADMIN_JWT_SECRET=CHANGE_ME_DIFFERENT_RANDOM_SECRET_32_CHARS

# --- Admin Access ---
ADMIN_KEY=CHANGE_ME_ADMIN_API_KEY
ADMIN_INITIAL_PASSWORD=CHANGE_ME_AT_FIRST_LOGIN

# (v583) Admin wallet whitelist — comma-separated Solana addresses.
#   Empty (default) = no whitelist; any connected Phantom wallet is OK.
#   Configured = all admin API calls (read+write) require the
#   X-Admin-Wallet header to contain an address in this list.
#   Combined with JWT login this is a 2-factor admin gate.
#   Example for multiple admins (one entry per allowed wallet):
#   ADMIN_WALLET_ADDRESSES=7oWYGTGQwDDvpT77Q3KzDuXu74kTbwBgxuEcktEGB2tU,9Z5h2hyFY3FGvBsSEU8EBt9ddkDXc2dQZp3Pg5iYzkL1
ADMIN_WALLET_ADDRESSES=

# --- Cron ---
# (audit M5 fix · 2026-06-12) 이자/배당/환율 cron endpoint 인증 키.
# 미설정 시 cron endpoint 가 401 fail-closed — 매월 15일 이자/배당 자동
# 지급이 전부 멈춥니다. Hostinger cron URL 의 ?key= 값과 일치해야 함.
# 64자 hex 권장: php -r "echo bin2hex(random_bytes(32));"
CRON_KEY=

# --- DB 자동 마이그레이션 ---
# (audit H2-1 fix · 2026-06-12) 자동 DB 스키마 마이그레이션 on/off.
# 기본 true (미설정 시 현 동작 — 요청 중 자동 컬럼/테이블 추가 + admin 로그인 시
# sql/ 패치 자동 적용). 운영 안정성을 위해 끄려면 0/false/no/off 로 설정.
# ⚠ 끄면 배포 후 반드시 수동 적용 필요: POST/GET /api/admin/db/migrate (adminOnly)
#   → sql/ 패치 + db.php 인라인 DDL 둘 다 적용. 깜빡하면 새 컬럼 없어 코드가 깨짐.
AUTO_MIGRATE_ENABLED=true

# --- OTP (Google Authenticator) ---
# Base32 encoded TOTP secret (32 chars)
OTP_SECRET_KEY=YOUR_TOTP_BASE32_SECRET

# --- Testing Bypasses (set to 0 in production!) ---
BYPASS_OTP=0
BYPASS_KYC=0

# --- Solana Network ---
# (참고) SOLANA_NETWORK 환경변수는 코드상 사용처가 없다 — 네트워크 선택은
#       admin/settings.html "Solana 네트워크" 에서 저장되는 DB 설정
#       `solana_network` 만 권위가 있다. 아래 줄은 운영 문서용 cosmetic.
SOLANA_NETWORK=devnet
#
# (2026-06-07 v862) Helius RPC — 네트워크별 분리 보관 권장.
#   silica.env 에 양쪽 키 모두 입력해두고, admin 패널 → 설정 →
#   "Solana 네트워크" 에서 devnet/mainnet 선택하면 매칭되는 키가
#   자동 적용된다. admin 패널 RPC URL 필드는 응급 override 용으로만 사용.
HELIUS_RPC_URL_MAINNET=https://mainnet.helius-rpc.com/?api-key=YOUR_MAINNET_KEY
HELIUS_RPC_URL_DEVNET=https://devnet.helius-rpc.com/?api-key=YOUR_DEVNET_KEY
# (Legacy) 단일 키 운영 환경 호환용 — 위 두 키를 사용하면 비워둬도 됨.
HELIUS_RPC_URL=

# Admin withdraw signing keypair (JSON array of 64 bytes)
# Generate: solana-keygen new --outfile admin-keypair.json
ADMIN_WITHDRAW_KEYPAIR_JSON=[1,2,3,...64 bytes]

# --- Token Mints (also configurable via admin/settings.html) ---
# USDT_MINT=Es9vMFrzaCERmJfrF4H2FYD4KCoNkY11McCe8BenwNYB    # Mainnet
# USDT_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU    # Devnet
# SILICA_STO_MINT=                                          # Set after SPL deploy
# SILICA_TOKEN_MINT=                                        # Set after SPL deploy

# --- KYC Provider (didit.me) ---
DIDIT_API_KEY=YOUR_DIDIT_API_KEY
DIDIT_WEBHOOK_SECRET=YOUR_DIDIT_WEBHOOK_SECRET

# --- Email (SMTP for outgoing notifications) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@silicachain.io
SMTP_PASSWORD=CHANGE_ME_SMTP_APP_PASSWORD
SMTP_FROM=noreply@silicachain.io
SMTP_FROM_NAME=SilicaChain

# --- CORS ---
# Comma-separated list of allowed origins. NO trailing slash. HTTPS only.
# Same-origin requests (frontend served from the same domain as the API) do NOT
# require any entry here. Add origins only if you serve the frontend from a
# different domain or have external integrations (mobile app, partner widget).
# Wildcard (*) is explicitly checked for and warned in error_log on boot.
CORS_ORIGIN=https://silicarwa.kolstoken.com

# --- Korea Bank API (USDT/KRW FX) ---
KOREA_BANK_API_URL=https://www.koreaexim.go.kr/site/program/financial/exchangeJSON
KOREA_BANK_API_KEY=YOUR_KOREAEXIM_AUTHKEY
