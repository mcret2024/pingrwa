# ============================================================
# Recon RWA Platform - Environment Variables
# Copy this file to .env and fill in your values
#
# (audit L1 정리 · 2026-06-12) PHP 배포의 authoritative 예시는
# php-api/.env.example 입니다. 이 루트 파일은 참고용 — 두 파일의
# 기본값이 다를 경우 php-api/.env.example 을 따르세요.
# 운영 (production) 에서는 BYPASS_OTP=0, BYPASS_KYC=0 이 필수입니다.
# ============================================================

# --- Server ---
PORT=4010
NODE_ENV=production

# --- MySQL Database (Hostinger) ---
# Hostinger format: u123456789_dbname
DB_HOST=localhost
DB_PORT=3306
DB_USER=u123456789_rwa
DB_PASSWORD=YOUR_DB_PASSWORD_HERE
DB_NAME=u123456789_rwa

# --- Paths (Hostinger Shared Hosting) ---
# Public directory: where admin/ and user/ HTML files are served from
# Hostinger example: /home/u123456789/domains/yourdomain.com/public_html
PUBLIC_DIR=/home/u123456789/domains/yourdomain.com/public_html

# Upload directory: where PDF/image uploads are stored
# Hostinger example: /home/u123456789/domains/yourdomain.com/public_html/uploads
UPLOAD_DIR=/home/u123456789/domains/yourdomain.com/public_html/uploads

# --- JWT ---
JWT_SECRET=YOUR_JWT_SECRET_CHANGE_THIS_TO_RANDOM_STRING
ADMIN_JWT_SECRET=YOUR_ADMIN_JWT_SECRET_CHANGE_THIS

# --- Admin ---
ADMIN_KEY=YOUR_ADMIN_API_KEY

# --- Cron ---
# (audit M5 fix · 2026-06-12) 이자/배당/환율 cron endpoint 인증 키.
# 미설정 시 cron endpoint 가 401 fail-closed — 매월 15일 이자/배당 자동
# 지급이 전부 멈춥니다. Hostinger cron URL 의 ?key= 값과 일치해야 함.
# 64자 hex 권장: php -r "echo bin2hex(random_bytes(32));"
CRON_KEY=

# --- DB 자동 마이그레이션 ---
# (audit H2-1 fix · 2026-06-12) 자동 DB 스키마 마이그레이션 on/off.
# 기본 true (미설정 시 현 동작). 끄려면 0/false/no/off.
# ⚠ 끄면 배포 후 수동 적용 필요: POST/GET /api/admin/db/migrate (adminOnly).
# 자세한 안내는 php-api/.env.example 참조 (authoritative).
AUTO_MIGRATE_ENABLED=true

# --- OTP (Google Authenticator) ---
OTP_SECRET_KEY=YOUR_BASE32_OTP_SECRET

# --- OTP/KYC Bypass ---
# (audit H4 fix · 2026-06-12) 기본값을 0 (안전) 으로 변경.
# 로컬/개발 환경에서 테스트할 때만 1 로 변경하세요.
# 운영 (production) 에서 1 이면 OTP/KYC 보안이 완전히 꺼집니다.
BYPASS_OTP=0
BYPASS_KYC=0

# --- Solana RPC ---
# (2026-06-07 v862) 네트워크별 분리 보관 — silica.env 에 양쪽 키 모두
# 입력해두고, admin 패널 → 설정 → "Solana 네트워크" 에서 devnet/mainnet
# 선택하면 매칭되는 키가 자동 적용된다. admin 패널 RPC URL 필드는
# 응급 override 용으로만 사용 (보통 비워둠).
HELIUS_RPC_URL_MAINNET=https://mainnet.helius-rpc.com/?api-key=YOUR_MAINNET_KEY
HELIUS_RPC_URL_DEVNET=https://devnet.helius-rpc.com/?api-key=YOUR_DEVNET_KEY
# (Legacy) 단일 키 운영 환경 호환용 — 위 두 키를 사용하면 비워둬도 됨.
HELIUS_RPC_URL=

# --- Admin Withdraw Keypair (JSON array of 64 bytes) ---
# ADMIN_WITHDRAW_KEYPAIR_JSON=[1,2,3,...64 bytes]

# --- CORS ---
# Comma separated origins
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# --- FX Rates ---
# (2026-05-08) Operator policy bans baked-in FX defaults — KRW volatility
# makes any fixed rate dangerous. The system relies entirely on the FX
# worker chain (cron/fx_worker_cron.php) writing fx_quote_latest. When
# all providers fail, transactions throw via fxRequireKrwOrThrow().
# No FX_*_PER_USDT env variables are read anywhere in the codebase.

# --- Simulation (testing only, set to 0 in production) ---
ADMIN_SIMULATE_BALANCE_ENABLED=0

# --- New User Initial USDT (testing: set >0, production: 0) ---
NEW_USER_INITIAL_USDT=0

# --- KYC (Didit.me) ---
KYC_MODE=didit
DIDIT_API_KEY=
DIDIT_WORKFLOW_ID=
PUBLIC_BASE_URL=https://yourdomain.com

# --- FX Worker (rwa_quote.js) ---
QUOTE_INTERVAL_SEC=180
FX_PROVIDER=open.er-api.com
