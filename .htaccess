# RWA Platform - Hostinger Shared Hosting .htaccess
# Place this in public_html/

# ===== DirectoryIndex =====
# 서브디렉토리(/admin/, /user/)에서 index.html을 자동으로 서빙해야 함.
# 루트(/)는 아래 RewriteRule이 먼저 /user/index.html로 302 리다이렉트하므로
# DirectoryIndex를 활성화해도 영향 없음.
DirectoryIndex index.html index.php

RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ===== (audit H8 fix · 2026-06-12) 개발/백업/내부 문서 웹 노출 차단 =====
# 정책: 파일은 repo 에 보존 (운영자 지침 — 삭제 대신 보존), 웹 접근만 403 차단.
# 실측 (2026-06-12): PROJECT_AUDIT_REPORT.md / PRODUCTION_CHECKLIST.md / rwa.sql /
#   preview-router.php 가 운영 도메인에서 200 으로 노출 중이었음. _backup/ 은
#   디렉토리 목록만 403, 내부 파일은 직접 경로로 접근 가능한 상태였음.
# 주의: 이 블록은 아래 real-file serve 룰보다 반드시 먼저 와야 함.
RewriteRule ^\.git(/|$) - [F,L]
RewriteRule ^_backup(/|$) - [F,L]
RewriteRule ^_manual_build(/|$) - [F,L]
RewriteRule ^sql(/|$) - [F,L]
RewriteRule ^php-api/vendor(/|$) - [F,L]
RewriteRule ^preview-router\.php$ - [F,L]
RewriteRule (^|/)preview-mode\.html$ - [F,L]
RewriteRule \.backup[^/]*$ - [F,L]
RewriteRule \.(sql|md)$ - [F,L]

# ===== ROOT URL REDIRECT =====
# This MUST come first, before any file-existence checks.
# (2026-05-26 v826) 처음 방문자가 대시보드(index.html) 를 잠시 보고
#   landing.html 로 redirect 되는 FOUC 깜빡임을 제거하기 위해, 루트 진입을
#   직접 landing.html 로 보낸다. 지갑 연결한 사용자는 랜딩의 "Connect Wallet"
#   버튼을 누르면 자동으로 index.html (대시보드) 로 이동한다.
RewriteRule ^/?$ /user/trade.html [L,R=302]

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ===== (2026-06-17 v917) gzip/deflate 압축 =====
# i18n.js(406KB) 등 큰 텍스트 자산의 전송량을 대폭 축소. LiteSpeed/Apache
# mod_deflate 호환. 서버가 이미 압축 중이어도 무해(중복 지시는 무시됨).
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml \
        text/javascript application/javascript application/x-javascript \
        application/json application/xml image/svg+xml
</IfModule>

# ===== 정적 자산 캐싱 (프로덕션) =====
# JS/CSS/이미지는 쿼리스트링 ?v=YYYYMMDDxx 캐시 버스터가 있으므로 장기 캐시 가능.
# HTML은 매 요청 재검증(no-cache) — 즉시 신규 버전 반영 보장.
<IfModule mod_headers.c>
    <FilesMatch "\.(js|css|png|jpg|jpeg|gif|ico|svg|webp|woff|woff2|ttf)$">
        Header set Cache-Control "public, max-age=3600, must-revalidate"
    </FilesMatch>
    <FilesMatch "\.html$">
        Header set Cache-Control "no-cache, must-revalidate"
        Header set Pragma "no-cache"
    </FilesMatch>
</IfModule>

# Prevent directory listing (for subdirectories only;
# root is handled by the RewriteRule above)
Options -Indexes

# ===== Fallback: if 403 still occurs, redirect to user page =====
ErrorDocument 403 /user/index.html

# (2026-06-08 v888) uploads RewriteRule 을 real-file check 보다 먼저 실행.
#   silica/uploads/.htaccess 가 git tracked 라서 deploy 시 빈 디렉토리
#   /public_html/rwa/uploads/ 가 생성됨. 그 결과 아래 real-file -d 매칭이
#   먼저 true 가 되어 uploads RewriteRule 가 실행 안 되고, Apache 가 디렉토리
#   안에서 파일 찾다가 실패 → 404 (사용자 서명 / silica_logo / 자산 이미지
#   모두 영향). uploads 룰을 위로 이동하여 PHP serve 라우트 위임을 보장.
RewriteRule ^uploads/([^/]+)$ /api/file/$1 [L]

# Serve real files directly (admin/, user/ static files)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Route /assets/* to /user/assets/* (for root-level access)
# 주의: 절대경로(/user/...)를 target으로 써야 Apache가 외부 307 redirect 대신 내부 rewrite로 처리함.
# 기존 상대경로는 Hostinger 환경에서 12초 수준의 redirect 루프를 유발.
RewriteRule ^assets/(.*)$ /user/assets/$1 [L]

# Route all /api/* requests to the PHP API router
RewriteRule ^api(/.*)?$ php-api/index.php [L,QSA]

# Block access to sensitive files
<FilesMatch "(\.env|\.git|composer\.(json|lock)|vendor/)">
    Order allow,deny
    Deny from all
</FilesMatch>
