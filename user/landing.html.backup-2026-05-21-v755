  .btn { display: inline-flex; align-items: center; justify-content: center; gap: 8px; padding: 12px 24px; font-family: 'Oswald', sans-serif; font-size: 13px; font-weight: 800; letter-spacing: 2px; text-transform: uppercase; border: none; cursor: pointer; border-radius: var(--r-sm); transition: all var(--t); text-decoration: none; }
