    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 12px;
    border-radius: 100px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 10px;
    letter-spacing: 1.5px;
    font-weight: 800;
