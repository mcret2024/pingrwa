<!-- i18n boot (RECON-compatible) -->
<script>
  (function () {
    try {
      var key = 'rwa_lang_user_v1';
      var raw = String(localStorage.getItem(key) || 'en').trim().toLowerCase();
      var lang = /^(ko|en)$/.test(raw) ? raw : 'ko';
      var de = document.documentElement;
      de.lang = lang;
      de.setAttribute('data-rwa-lang', lang);
      de.setAttribute('data-rwa-i18n-ready', '1');
      window.__RWA_I18N_BOOT_LANG__ = lang;
    } catch (_) {}
  })();
</script>

<!-- (2026-05-19 v589) 운영자 요청: '로그인 하면 이 페이지와 About 메뉴 보이지
     않게 숨기기.' core.js 가 wallet 상태를 'rwa_wallet_v3' 키로 저장 (
     STORAGE.wallet). connected:true 이면 즉시 index.html 로 replace 하여
     랜딩 페이지가 노출되지 않게 함. ?force=1 쿼리로 우회 가능 (개발 목적). -->
<script>
  (function () {
    try {
      if (new URLSearchParams(location.search).get('force') === '1') return;
      var raw = localStorage.getItem('rwa_wallet_v3') || '';
      if (!raw) return;
      var w = JSON.parse(raw);
      if (w && w.connected === true && w.address) {
        location.replace('index.html');
      }
    } catch (_) {}
  })();
</script>

<style>
  /* ============ LANDING PAGE — STELLAR AURORA ============ */
