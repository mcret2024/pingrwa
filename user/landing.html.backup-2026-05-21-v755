<script src="assets/js/app.js?v=20260521v730-index-exempt"></script>
<!-- (2026-05-18 v469/v471) DUAL TOKEN ARCHITECTURE 섹션 라이브 바인딩.
     /api/public/config 1회 fetch 로 두 필드 갱신:
       - silica_price_usdt → #landingSilicaPrice  (Silica 토큰 시세, v469)
       - silica_apr_pct    → #landingStakingApr   (SilicaSTO Staking APR, v471)
     둘 다 admin 설정/사이클 변경 시 즉시 반영. 누락 시 폴백 텍스트. -->
<script>
  (function () {
    const _lang = (() => {
      try {
        const v = String(localStorage.getItem('rwa_lang_user_v1') || 'en').trim().toLowerCase();
        return v === 'ko' ? 'ko' : 'en';
      } catch (_) { return 'en'; }
    })();

    const applyPrice = (val) => {
      const el = document.getElementById('landingSilicaPrice');
      if (!el) return;
      const price = Number(val);
      const hasPrice = isFinite(price) && price > 0;
      const display = hasPrice
        ? (price < 1 ? price.toFixed(4).replace(/0+$/, '').replace(/\.$/, '') : price.toFixed(2))
        : '—';
      if (_lang === 'ko') {
        el.textContent = hasPrice
          ? `변동 (현재 ${display} USDT)`
          : `변동 (시세 미설정)`;
      } else {
        el.textContent = hasPrice
          ? `Variable (currently ${display} USDT)`
          : `Variable (price not set)`;
      }
    };

    const applyApr = (val) => {
      const el = document.getElementById('landingStakingApr');
      const heroEl = document.getElementById('landingHeroApr'); // (v508) Hero APR 카드
      const apr = Number(val);
      const hasApr = isFinite(apr) && apr > 0;
      // 정수면 정수 표기, 소수점 있으면 최대 2자리.
      const display = hasApr
        ? (Number.isInteger(apr) ? String(apr) : apr.toFixed(2).replace(/0+$/, '').replace(/\.$/, ''))
        : '—';
      if (el) {
        if (_lang === 'ko') {
          el.textContent = hasApr
            ? `가능 (${display}% USDT 이자)`
            : `가능 (이자율 미설정)`;
        } else {
          el.textContent = hasApr
            ? `Available (${display}% USDT Interest)`
            : `Available (rate not set)`;
        }
      }
      // (v508) Hero APR 카드 — '5.00%' 형식의 큰 표기 + 소수부 small 태그
      if (heroEl) {
        if (hasApr) {
          const intPart = Math.floor(apr);
          const decPart = Math.round((apr - intPart) * 100);
          const decStr = decPart > 0
            ? '.' + (decPart < 10 ? '0' + decPart : decPart) + '%'
            : '.00%';
          heroEl.innerHTML = `${intPart}<small>${decStr}</small>`;
        } else {
          heroEl.innerHTML = '—<small>.--%</small>';
        }
      }
    };

    const apiBase = (() => {
      try {
        const v = localStorage.getItem('rwa_api_base_v1');
        if (v) return String(v).replace(/\/+$/, '');
      } catch (_) {}
      return '';
    })();
    fetch(`${apiBase}/api/public/config`, { method: 'GET', cache: 'no-store' })
      .then(r => r.json())
      .then(d => {
        applyPrice(d?.silica_price_usdt);
        applyApr(d?.silica_apr_pct);
      })
      .catch(err => {
        console.warn('[landing] dual-token config fetch failed:', err?.message || err);
        applyPrice(0);
        applyApr(0);
      });
  })();
</script>
